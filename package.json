{
    "name": "auth-service",
    "version": "1.0.0",
    "description": "The user management service.",
    "main": "index.js",
    "scripts": {
        "dev": "cross-env NODE_ENV=dev nodemon src/server.ts",
        "build": "npx tsc",
        "format:fix": "prettier . --write",
        "format:check": "prettier . --check",
        "lint:check": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "jest --watch --runInBand",
        "prepare": "husky",
        "start": "ts-node src/index.ts",
        "migration:generate": "typeorm-ts-node-commonjs migration:generate",
        "migration:run": "typeorm-ts-node-commonjs migration:run",
        "migration:new": "typeorm-ts-node-commonjs migration:create"
    },
    "license": "ISC",
    "author": "Prashnat gupta",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@jest/globals": "^30.4.1",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.6",
        "@types/http-errors": "^2.0.5",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.9.3",
        "@types/supertest": "^7.2.0",
        "@types/winston": "^2.4.4",
        "cross-env": "^10.1.0",
        "dotenv": "^17.4.2",
        "eslint": "^10.5.0",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "lint-staged": "^17.0.7",
        "mock-jwks": "^1.0.10",
        "nodemon": "^3.1.14",
        "prettier": "3.8.4",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.61.0"
    },
    "lint-staged": {
        "*.ts": [
            "npm run format:fix",
            "npm run lint:fix"
        ]
    },
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "express": "^5.2.1",
        "express-jwt": "^8.4.1",
        "express-validator": "^7.3.2",
        "http-errors": "^2.0.1",
        "jsonwebtoken": "^9.0.3",
        "jwks-rsa": "^3.1.0",
        "pg": "^8.22.0",
        "reflect-metadata": "^0.2.2",
        "rsa-pem-to-jwk": "^1.1.3",
        "typeorm": "1.0.0",
        "winston": "^3.19.0"
    }
}
